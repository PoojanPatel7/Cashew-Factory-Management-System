generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// -----------------------------------------------------------------------------
// FACTORY & AUTH
// -----------------------------------------------------------------------------

model Factory {
  id                String           @id @default(uuid())
  name              String
  weighAtEveryStage Boolean          @default(true)
  users             User[]
  rawStocks         RawStock[]
  sortings          Sorting[]
  lots              Lot[]
  processingSteps   ProcessingStep[]
  finishedStocks    FinishedStock[]
  dispatches        Dispatch[]
  activityLogs      ActivityLog[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String   @default("OWNER")
  name         String   @default("Factory Owner")
  factoryId    String?
  factory      Factory? @relation(fields: [factoryId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// RAW STOCK — Cashew arrives at the factory
// -----------------------------------------------------------------------------

model RawStock {
  id                 String    @id @default(uuid())
  name               String    @default("Un-named Batch")
  weight             Float                // kg received
  usedWeight         Float     @default(0) // kg already sent to sorting
  date               DateTime  @default(now())
  note               String?
  originalRawStockId String?              // Tracks if this was transferred from another raw stock
  factoryId          String?
  factory            Factory?  @relation(fields: [factoryId], references: [id])
  sortings           Sorting[]
  sortingRawStocks   SortingRawStock[]
  createdAt          DateTime  @default(now())
}

// -----------------------------------------------------------------------------
// SORTING — Raw stock is separated into lots by category/size
// -----------------------------------------------------------------------------

model SortingRawStock {
  id          String   @id @default(uuid())
  sortingId   String
  sorting     Sorting  @relation(fields: [sortingId], references: [id], onDelete: Cascade)
  rawStockId  String
  rawStock    RawStock @relation(fields: [rawStockId], references: [id], onDelete: Restrict)
  weight      Float
}

model Sorting {
  id          String   @id @default(uuid())
  rawStockId  String?  // Keep optional for old data if any
  rawStock    RawStock? @relation(fields: [rawStockId], references: [id])
  totalWeight Float              // total kg being sorted
  date        DateTime @default(now())
  note        String?
  factoryId   String?
  factory     Factory? @relation(fields: [factoryId], references: [id])
  lots        Lot[]
  rawStocks   SortingRawStock[]
  createdAt   DateTime @default(now())
}

// -----------------------------------------------------------------------------
// LOT — Individual lot created from sorting (e.g., "W240 - 500kg")
// -----------------------------------------------------------------------------

model Lot {
  id            String           @id @default(uuid())
  sortingId     String
  sorting       Sorting          @relation(fields: [sortingId], references: [id])
  name          String                     // e.g., "Large Grade A"
  category      String                     // e.g., "W180", "W240", "W320", "Broken"
  initialWeight Float                      // kg at start
  currentWeight Float                      // kg at current stage
  currentStage  String           @default("PENDING")
  status        String           @default("PENDING") // PENDING, PROCESSING, COMPLETED
  note          String?
  splitFromLotId String?         // Tracks which lot this was split from (e.g. pre-packaging sorting)
  factoryId     String?
  factory       Factory?         @relation(fields: [factoryId], references: [id])
  steps         ProcessingStep[]
  finishedStock FinishedStock?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

// -----------------------------------------------------------------------------
// PROCESSING STEP — Each stage completion for a lot
// -----------------------------------------------------------------------------

model ProcessingStep {
  id           String   @id @default(uuid())
  lotId        String
  lot          Lot      @relation(fields: [lotId], references: [id], onDelete: Cascade)
  stageName    String              // CLEANING, BOILING, COOLING, PRE_PACKAGING_SORTING
  subProcessName String?           // Fine-grained sub-processes within a stage
  sortingMethod  String?           // 'MANUAL' or 'MACHINE' (for pre-packaging sorting)
  inputWeight  Float?              // Made optional for factory.weighAtEveryStage = false
  outputWeight Float?
  wastage      Float?              // auto-calculated if weights are provided
  note         String?
  completedBy  String?             // operator name (optional)
  factoryId    String?
  factory      Factory?            @relation(fields: [factoryId], references: [id])
  completedAt  DateTime @default(now())
}

// -----------------------------------------------------------------------------
// FINISHED STOCK — Lot completed all stages, packed and ready
// -----------------------------------------------------------------------------

model FinishedStock {
  id           String     @id @default(uuid())
  lotId        String     @unique
  lot          Lot        @relation(fields: [lotId], references: [id])
  packedWeight Float
  dispatched   Float      @default(0)
  note         String?
  factoryId    String?
  factory      Factory?   @relation(fields: [factoryId], references: [id])
  completedAt  DateTime   @default(now())
  dispatches   Dispatch[]
}

// -----------------------------------------------------------------------------
// DISPATCH — Stock leaving the factory
// -----------------------------------------------------------------------------

model Dispatch {
  id              String        @id @default(uuid())
  finishedStockId String
  finishedStock   FinishedStock @relation(fields: [finishedStockId], references: [id])
  weight          Float
  note            String?
  factoryId       String?
  factory         Factory?      @relation(fields: [factoryId], references: [id])
  date            DateTime      @default(now())
}

// -----------------------------------------------------------------------------
// ACTIVITY LOG — Track every action with timestamp
// -----------------------------------------------------------------------------

model ActivityLog {
  id        String   @id @default(uuid())
  action    String              // "STOCK_ADDED", "SORTING_DONE", etc.
  detail    String              // Human-readable description
  weight    Float?              // Related weight
  factoryId String?
  factory   Factory?            @relation(fields: [factoryId], references: [id])
  timestamp DateTime @default(now())
}
